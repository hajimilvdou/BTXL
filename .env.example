# Example environment configuration for BTXL.
# Copy this file to `.env` and uncomment the variables you need.
#
# NOTE: Environment variables are only required when using remote storage options.
# For local file-based storage (default), no environment variables need to be set.

# ------------------------------------------------------------------------------
# OAuth Credentials (required for Gemini / Antigravity auth flows)
# ------------------------------------------------------------------------------
# GEMINI_OAUTH_CLIENT_ID=your-gemini-client-id.apps.googleusercontent.com
# GEMINI_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTIGRAVITY_OAUTH_CLIENT_ID=your-antigravity-client-id.apps.googleusercontent.com
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# Management Web UI
# ------------------------------------------------------------------------------
# MANAGEMENT_PASSWORD=change-me-to-a-strong-password

# ------------------------------------------------------------------------------
# Docker Mount Paths (optional)
# ------------------------------------------------------------------------------
# BTXL_PORT=8317
# BTXL_CONFIG_DIR=./data/config
# BTXL_AUTH_PATH=./data/auths
# BTXL_LOG_PATH=./data/logs

# ------------------------------------------------------------------------------
# Postgres Token Store (optional)
# ------------------------------------------------------------------------------
# PGSTORE_DSN=postgresql://user:pass@localhost:5432/btxl
# PGSTORE_SCHEMA=public
# PGSTORE_LOCAL_PATH=/var/lib/btxl

# ------------------------------------------------------------------------------
# Git-Backed Config Store (optional)
# ------------------------------------------------------------------------------
# GITSTORE_GIT_URL=https://github.com/your-org/btxl-config.git
# GITSTORE_GIT_USERNAME=git-user
# GITSTORE_GIT_TOKEN=ghp_your_personal_access_token
# GITSTORE_LOCAL_PATH=/data/btxl/gitstore

# ------------------------------------------------------------------------------
# Object Store Token Store (optional)
# ------------------------------------------------------------------------------
# OBJECTSTORE_ENDPOINT=https://s3.your-cloud.example.com
# OBJECTSTORE_BUCKET=btxl-config
# OBJECTSTORE_ACCESS_KEY=your_access_key
# OBJECTSTORE_SECRET_KEY=your_secret_key
# OBJECTSTORE_LOCAL_PATH=/data/btxl/objectstore
